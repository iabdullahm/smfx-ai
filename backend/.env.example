# Environment
APP_ENV=development
APP_NAME=SMFX-AI
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite default — switch to Postgres in prod)
DATABASE_URL=sqlite:///./smfx.db

# Security
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Data providers
USE_LIVE_DATA=1
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Payments — NOWPayments (fiat→USDT)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000

# Signal generation
SIGNAL_STRENGTH_THRESHOLD=6.0
